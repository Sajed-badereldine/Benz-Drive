# ==============================================================================
# BenzDrive Backend Environment Variables Example Configuration
# Copy this file to '.env' and adjust the settings for your local/prod deployment.
# ==============================================================================

# Database configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_database_password
DB_DATABASE=benzdrive

# JWT configuration
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production
JWT_EXPIRES_IN=7d

# Mail configuration (e.g. SMTP server like Mailtrap, Resend, or AWS SES)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_FROM=no-reply@benzdrive.com

# AWS S3 configuration (Active storage bucket)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET_NAME=benzdrive-bucket
AWS_S3_ENDPOINT=http://localhost:4566 # Optional: Override for local mocks (e.g., LocalStack/MinIO)

# Frontend interface base URL
FRONTEND_URL=http://localhost:5233
