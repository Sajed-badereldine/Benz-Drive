# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Node / Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build directories
dist/
build/
.next/
out/

# IDE / System files
.DS_Store
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# ==============================================================================
# Terraform Ignores
# ==============================================================================

# Local .terraform path containing downloaded modules and provider plugins
**/.terraform/

# Local state files (can contain decrypted sensitive environment variables)
**/*.tfstate
**/*.tfstate.*

# Crash log files
**/crash.log
**/crash.*.log

# Exclude all variable files since they contain secrets/passwords
**/*.tfvars
**/*.tfvars.json

# Ignore override files containing developer-specific overrides
**/override.tf
**/override.tf.json
**/_override.tf
**/_override.tf.json

# Ignore CLI configuration files
**/.terraformrc
**/terraform.rc
